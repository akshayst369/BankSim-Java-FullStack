<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">
    <servlet>
        <servlet-name>CreateAccount</servlet-name>
        <servlet-class>com.bank.CreateAccountServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CreateAccount</servlet-name>
        <url-pattern>/CreateAccountServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.bank.LoginServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/LoginServlet</url-pattern>
</servlet-mapping>
    
    
    <servlet>
    <servlet-name>DepositServlet</servlet-name>
    <servlet-class>com.bank.DepositServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DepositServlet</servlet-name>
    <url-pattern>/DepositServlet</url-pattern>
</servlet-mapping>
    
    <servlet>
    <servlet-name>WithdrawServlet</servlet-name>
    <servlet-class>com.bank.WithdrawServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>WithdrawServlet</servlet-name>
    <url-pattern>/WithdrawServlet</url-pattern>
</servlet-mapping>
        
    <servlet>
    <servlet-name>DeleteAccountServlet</servlet-name>
    <servlet-class>com.bank.DeleteAccountServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteAccountServlet</servlet-name>
    <url-pattern>/DeleteAccountServlet</url-pattern>
</servlet-mapping>
    
    <servlet>
    <servlet-name>DashboardServlet</servlet-name>
    <servlet-class>com.bank.DashboardServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DashboardServlet</servlet-name>
    <url-pattern>/DashboardServlet</url-pattern>
</servlet-mapping>
    
    
    
</web-app>
